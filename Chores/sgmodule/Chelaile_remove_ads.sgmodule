#!name=车来了去广告
#!desc=清洗配置，移除开屏广告、首页金刚位、文章推荐，精简我的页面。
#!author=可莉🅥[https://github.com/luestr/ProxyResource/blob/main/README.md]
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/Chelaile.png
#!category=🚫 AD Block
#!openUrl=https://apps.apple.com/app/id667831823
#!category=去广告
#!loon_version=3.4.0(962)
#!homepage=https://hub.kelee.one
#!date=2026-07-04 19:58:28

[Rule]
DOMAIN,ad.chelaile.net.cn,REJECT

[URL Rewrite]
^https:\/\/cdn\.web\.chelaile\.net\.cn\/info-flow\/index\.html\? - reject

[Map Local]
^https:\/\/image3\.chelaile\.net\.cn\/hw6u6LYY\.png$ data-type=tiny-gif status-code=200

^https:\/\/api\.chelaile\.net\.cn\/goocity\/flowPos\/home\? data-type=text data="**YGKJ{"jsonr":{"status":"00","data":{"advertList":[{"id":106,"title":"站点地图","iconUrl":"https://image3.chelaile.net.cn/89iIqxaM.png","linkUrl":"","adType":5,"showRedDot":0,"updateTime":0,"appId":"","appPath":"","bubbleOrder":0,"h5Type":0},{"id":1,"title":"地铁","iconUrl":"https://image3.chelaile.net.cn/rewrLCWY.png","linkUrl":"https://web.chelaile.net.cn/metro/index.html?h5_stats_referer=icon","adType":2,"showRedDot":0,"updateTime":0,"appId":"","appPath":"","bubbleOrder":0,"h5Type":0}]}YGKJ##" status-code=200 header="Content-Type:application/json"

^https:\/\/api\.chelaile\.net\.cn\/goocity\/flowPos\/listByPos\? data-type=text data="**YGKJ{}YGKJ##" status-code=200 header="Content-Type:application/json"

^https:\/\/web\.chelaile\.net\.cn\/api\/operative_position\/infoflow\/getInfo\? data-type=text data="**YGKJ{}YGKJ##" status-code=200 header="Content-Type:application/json"

^https:\/\/api\.chelaile\.net\.cn\/led-weather\/v\d\/condition_brief\? data-type=text data="**YGKJ{}YGKJ##" status-code=200 header="Content-Type:application/json"

^https:\/\/api\.chelaile\.net\.cn\/goocity\/config\/notices\? data-type=text data="**YGKJ{}YGKJ##" status-code=200 header="Content-Type:application/json"

^https:\/\/api\.chelaile\.net\.cn\/encourage\/activity\/control\? data-type=text data="**YGKJ{}YGKJ##" status-code=200 header="Content-Type:application/json"

[Script]
清洗配置 = type=http-response, pattern=^https:\/\/api\.chelaile\.net\.cn\/bus-side\/appToggle\/getStatus\?, script-path=https://github.com/bunizao/Mirrored/raw/main/Chores/js/Chelaile_remove_ads.js, requires-body=true

[MITM]
hostname = %APPEND% api.chelaile.net.cn, web.chelaile.net.cn, cdn.web.chelaile.net.cn, image3.chelaile.net.cn

