[Script]
body_rewrite_12 = type=http-response, pattern=^https:\/\/api\.romielf\.com\/index\/indexv\d\?, script-path=https://github.com/bunizao/Mirrored/raw/main/Chores/js/body-rewrite.js, requires-body=true, max-size=-1, timeout=30, argument=%5B%5B%22json-replace%22%2C%5B%5B%22data.advertisement%22%2C%5B%5D%5D%2C%5B%22data.listadvertising%22%2C%5B%5D%5D%5D%5D%5D

[MITM]
hostname = %APPEND% api.romielf.com

